Private Function StartsWithText( _
    ByVal fullText As String, _
    ByVal startText As String) As Boolean
    If Len(fullText) < Len(startText) Then
        StartsWithText = False
        Exit Function
    End If
    StartsWithText = _
        Left$(fullText, Len(startText)) = startText
End Function
Private Sub ApplyTechnicalStyle( _
    ByVal technicalRange As Range)
    On Error Resume Next
    With technicalRange.Font
        .Name = "Times New Roman"
        .Size = 14
        .Bold = False
        .Italic = False
        .Color = wdColorBlue
        .Underline = wdUnderlineSingle
        .Position = 0
        .Spacing = 0
        .Superscript = False
        .Subscript = False
    End With
    technicalRange.HighlightColorIndex = _
        wdNoHighlight
    With technicalRange.ParagraphFormat
        .FirstLineIndent = 0
        .LeftIndent = 0
        .RightIndent = 0
        .SpaceBefore = 0
        .SpaceAfter = 0
        .LineSpacingRule = wdLineSpaceSingle
    End With
    On Error GoTo 0
End Sub
