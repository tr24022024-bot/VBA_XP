Option Explicit

Private Const SETTINGS_SHEET As String = "Настройки"
Private Const AGENTS_SHEET As String = "Агенты"

Private Const SECONDS_IN_DAY As Double = 86400#
Private Const PI_VALUE As Double = 3.14159265358979

'=========================================================
' СОЗДАНИЕ ЛИСТОВ И НАЧАЛЬНЫХ НАСТРОЕК
'=========================================================
Public Sub CreateDynamicCalendarModel()

    Dim wsSettings As Worksheet
    Dim wsAgents As Worksheet

    Application.ScreenUpdating = False

    Set wsSettings = GetOrCreateSheet(SETTINGS_SHEET)
    Set wsAgents = GetOrCreateSheet(AGENTS_SHEET)

    PrepareSettingsSheet wsSettings
    PrepareAgentsSheet wsAgents

    Application.ScreenUpdating = True

    MsgBox _
        "Динамическая календарная модель создана.", _
        vbInformation

End Sub

